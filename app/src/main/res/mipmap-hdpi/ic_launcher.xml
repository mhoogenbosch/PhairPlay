<?xml version="1.0" encoding="utf-8"?>
<!-- Fallback launcher icon for API < 26 (e.g. Fire TV with minSdk=25).
     layer-list is a valid non-adaptive icon format for all API levels. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/background_surface" />
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/accent_blue" />
        </shape>
    </item>
</layer-list>
